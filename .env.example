# Learn-RV environment variables
# Copy this file to .env and fill in your values.
# The .env file is gitignored — never commit it.

# ── Required ──────────────────────────────────────────────────────────────────

# Anthropic API key — required for: learn ask, learn apply, learn study,
# learn quiz, learn eval. Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# ── Optional ──────────────────────────────────────────────────────────────────

# Override the default KB storage location (default: ~/Docs/KB).
# All .rvf topic files and sidecar metadata live here.
# LEARN_KB_ROOT=~/Docs/KB

# Use a local LLM instead of Anthropic for synthesis.
# Requires a GGUF model at ~/.cache/learn-rs/models/ruvllm-default.gguf
# and the ruvllm runtime. Useful for air-gapped / offline setups.
# LEARN_SYNTH_LOCAL=1

# Hard-fail if AIMDS (AI safety guardrails) middleware is unavailable.
# Default: soft-fail (guardrails skipped with a warning).
# LEARN_AIMDS_REQUIRED=1

# Override the embedding model directory.
# Default: ~/.cache/learn-rs/models/bge-large-en-v15/
# LEARN_EMBED_MODEL_DIR=~/.cache/learn-rs/models/bge-large-en-v15

# Rust log level for the learn binary (e.g. warn, info, debug, trace).
# Default: warn
# RUST_LOG=warn
